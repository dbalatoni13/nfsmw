            WorldConn::Pkt_Body_Open pkt(mWorldID, mat);
            mBodyService = OpenService(UCrc32(0x998c21c0), &pkt);
        }
    }
    for (Behaviors::const_iterator iter = mBehaviors.begin(); iter != mBehaviors.end(); ++iter) {
        (*iter)->OnBehaviorChange(mechanic);
    }
}

