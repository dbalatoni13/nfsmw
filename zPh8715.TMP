bool Smackable::SimplifySort(const Smackable *lhs, const Smackable *rhs) {
    if (lhs->mSimplifyWeight > rhs->mSimplifyWeight) {
        return true;
    }
    if (lhs->mSimplifyWeight < rhs->mSimplifyWeight) {
        return false;
    }
    return lhs->GetInstanceHandle() < rhs->GetInstanceHandle();
}

