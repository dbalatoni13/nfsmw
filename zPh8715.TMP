    ELF32_Sym *symtab;                    
    ELFSectionHeader *sections;           
    ELFHeader *e;                         
    long unsigned int hash[256];          
    long unsigned int *chain;             
    bool *isOriginal;                     
    DynamicLoader *mpDynamicLoader;       
    DynamicUserCallback pSearchFunction;  
};

};  


