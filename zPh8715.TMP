class SimpleRigidBody : public Behavior, public IRigidBody, public ISimpleBody, public bTNode<SimpleRigidBody>, public Debugable {
  public:
     
    struct Volatile {
        Volatile();

        UMath::Vector4 orientation;  
        UMath::Vector3 position;     
        unsigned char unused;        
        unsigned char index;         
        unsigned short flags;        
        UMath::Vector3 linearVel;    
        float radius;                
        UMath::Vector3 angularVel;   
        float mass;                  
    };

     
    static Behavior *Construct(const struct BehaviorParams &params);
    static void Update(const float dT, void *workspace);
    static IRigidBody *Get(unsigned int index);
    static unsigned int AssignSlot();

     
    SimpleRigidBody(const BehaviorParams &bp, const RBSimpleParams &params);
    float GetScalarVelocity() const;
    void ApplyFriction();
    void DoIntegration(const float dT);
    void RecalcOrientMat(UMath::Matrix4 &resultMat4) const;

     
    virtual void OnDebugDraw();

     
     
    ~SimpleRigidBody()  ;
    ISimable *GetOwner() const  ;
    void GetForwardVector(UMath::Vector3 &vec) const  ;
    void GetRightVector(UMath::Vector3 &vec) const  ;
    void GetUpVector(UMath::Vector3 &vec) const  ;
    void SetOrientation(const UMath::Matrix4 &orientMat)  ;
    void SetOrientation(const UMath::Vector4 &orientation)  ;
    void Accelerate(const UMath::Vector3 &a, float dT)  ;
    void GetPointVelocity(const UMath::Vector3 &worldPt, UMath::Vector3 &pv) const  ;
    void PlaceObject(const UMath::Matrix4 &orientMat, const UMath::Vector3 &initPos)  ;
    void ConvertLocalToWorld(UMath::Vector3 &val, bool translate) const  ;
    void ConvertWorldToLocal(UMath::Vector3 &val, bool translate) const  ;
    void Resolve(const UMath::Vector3 &force, const UMath::Vector3 &torque)  ;
    void ResolveForce(const UMath::Vector3 &force)  ;
    void ResolveForce(const UMath::Vector3 &, const UMath::Vector3 &)  ;
    void ResolveTorque(const UMath::Vector3 &torque)  ;
    unsigned int GetTriggerFlags() const  ;

     
     
    void OnTaskSimulate(float dT)   {}

    void Reset()   {}

     
    void ModifyFlags(unsigned int uRemove, unsigned int uAdd)   {
        mData->flags &= ~uRemove;
        mData->flags |= uAdd;
    }

    bool CanCollideWithSRB() const   {
        return !(mData->flags & 1);
    }

    bool CanCollideWithRB() const   {
        return !(mData->flags & 2);
    }

    bool CanHitTrigger() const   {
        return mData->flags & 0x100;
    }

    const SimCollisionMap *GetCollisionMap() const   {
        return &mCollisionMap[mData->index];
    }

    SimCollisionMap *GetCollisionMap()   {
        return &mCollisionMap[mData->index];
    }

     
    bool IsSimple() const   {
        return true;
    }

    SimableType GetSimableType() const   {
        return GetOwner()->GetSimableType();
    }

    int GetIndex() const   {
        return mData->index;
    }

    float GetRadius() const   {
        return mData->radius;
    }

    float GetMass() const   {
        return mData->mass;
    }

    float GetOOMass() const   {
        return 1.0f / mData->mass;
    }

    const UMath::Vector3 &GetPosition() const   {
        return mData->position;
    }

    const UMath::Vector3 &GetLinearVelocity() const   {
        return mData->linearVel;
    }

    const UMath::Vector3 &GetAngularVelocity() const   {
        return mData->angularVel;
    }

    float GetSpeed() const   {
        return UMath::Length(GetLinearVelocity());
    }

    float GetSpeedXZ() const   {
        return UMath::Lengthxz(GetLinearVelocity());
    }

    const WCollider *GetWCollider() const   {
        return __null  ;
    }

    void SetPosition(const UMath::Vector3 &pos)   {
        mData->position = pos;
    }

    void SetLinearVelocity(const UMath::Vector3 &vel)   {
        mData->linearVel = vel;
    }

    void SetAngularVelocity(const UMath::Vector3 &vel)   {
        mData->angularVel = vel;
    }

    void SetRadius(float radius)   {
        mData->radius = radius;
    }

    void SetMass(float mass)   {
        mData->mass = mass;
    }

    void ModifyXPos(float offset)   {
        mData->position.x += offset;
    }

    void ModifyZPos(float offset)   {
        mData->position.z += offset;
    }

    void ModifyYPos(float offset)   {
        mData->position.y += offset;
    }

    void ResolveTorque(const UMath::Vector3 &f, const UMath::Vector3 &p)   {}

    void GetMatrix4(UMath::Matrix4 &mat) const   {
        RecalcOrientMat(mat);
    }

    const UMath::Vector4 &GetOrientation() const   {
        return mData->orientation;
    }

    void GetDimension(UMath::Vector3 &dim) const   {
        dim.x = dim.y = dim.z = mData->radius;
    }

    UMath::Vector3 GetDimension() const   {
        UMath::Vector3 dim;
        dim.x = dim.y = dim.z = mData->radius;
        return dim;
    }

    bool HasHadCollision() const   {
        return false;
    }

    void Debug()   {}

     
    static unsigned int GetCount() {
        return mCount;
    }

    bool CheckAnyFlags(unsigned int flagsToCheck) const {
        return mData->flags & flagsToCheck;
    }

  private:
    static SimCollisionMap mCollisionMap[(96) ];
    static SimpleRigidBody *mMaps[(96) ];
    static unsigned int mCount;

    ScratchPtr<Volatile> mData;  
};

