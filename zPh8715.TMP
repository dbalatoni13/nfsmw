namespace UTL {
namespace Std {

template <typename T, typename Tag> struct vector : public _STL   ::vector<T, UTL::Std::Allocator<T, Tag> > {
  private:
    typedef _STL   ::vector<T, UTL::Std::Allocator<T, Tag> > _Base;

  public:
    void push_back(const typename _Base::value_type &_Val) {
        _Base::push_back(_Val);
    }

    typename _Base::iterator insert(typename _Base::iterator _Where, typename _Base::const_reference _Val) {
        return _Base::insert(_Where, _Val);
    }

    typename _Base::reference operator[](typename _Base::size_type _Pos) {
        return *(_Base::begin() + _Pos);
    }
};

template <typename T, typename Tag> struct list : public _STL   ::list<T, UTL::Std::Allocator<T, Tag> > {};
template <typename Key, typename T, typename Tag> struct map : public _STL   ::map<Key, T, _STL   ::less<Key>, UTL::Std::Allocator<T, Tag> > {};
template <typename T, typename Tag> struct set : public _STL   ::set<T, _STL   ::less<T>, UTL::Std::Allocator<T, Tag> > {};

 
 
 

};  
