        return gFastMem.Alloc(size, __null  );
    }

    void operator delete(void *mem, size_t size) {
        if (mem) {
            gFastMem.Free(mem, size, __null  );
        }
    }

    WWorldPos(float yOffset) {
        fFace.fSurface.fSurface = 0;
        fFace.fSurface.fFlags = 0;
        this->fYOffset = yOffset;
        this->fFaceValid = 0;
        this->fMissCount = 0;
        this->fUsageCount = 0;
        this->fSurface = __null  ;
        fFace.fPt0 = UMath::Vector3::kZero;
        fFace.fSurfaceRef = __null  ;
        fFace.fPt1 = UMath::Vector3::kZero;
        fFace.fFlags = 0;
        fFace.fPt2 = UMath::Vector3::kZero;
        fFace.PAD = 0;
    }

    ~WWorldPos() {}

     

    bool OnValidFace() const { return fFaceValid != 0; }

    void ForceFaceValidity() {}

     

    void SetTolerance(float liftAmount) {
        fYOffset = liftAmount;
    }

    void UNormal(UMath::Vector3 *norm) const {}

    void UNormal(UMath::Vector4 *norm) const {}

     

    const Attrib::Collection *GetSurface() const {
        return fSurface;
    }

     

  private:
    WCollisionTri fFace;                 
    unsigned int fFaceValid : 1;         
    unsigned int fMissCount : 15;        
    unsigned int fUsageCount : 16;       
    float fYOffset;                      
    const Attrib::Collection *fSurface;  
};


