# 1 "src/Speed/Indep/Tools/AttribSys/Runtime/AttribHash.h" 1









namespace Attrib {

unsigned long long StringHash64(const char *k);
unsigned int StringHash32(const char *k);

class StringKey {
  public:
    StringKey() {
        mHash64 = 0;
        mHash32 = 0;
        mString = "";
    }

    StringKey(const char *str) {
        mHash64 = StringHash64(str);
        mHash32 = StringHash32(str);
        mString = str;
    }

    bool operator==(const StringKey &rhs) const {
        return mHash64 == rhs.mHash64;
    }

    operator long long() const {
        return this->mHash64;
    }

    operator unsigned int() const {
        return mHash32;
    }

    unsigned int GetHash32() const {
        return mHash32;
    }

    bool IsValid() const {
        return mString != __null  ;
    }

    bool IsNotEmpty() const {
        return mString != __null   && mString[0] != '\0';
    }

    const char *GetString() const {
        return mString;
    }

  private:
     
    unsigned long long mHash64;  
    unsigned int mHash32;        
    const char *mString;         
};

 
class StringKeyPtr {
    static const StringKey gDefault;

    const StringKey *mKey;  
};

}  


# 9 "src/Speed/Indep/Libs/Support/Utility/UCrc.h" 2


class bHash32 {
    unsigned int mCRC;

  public:
    bHash32() {}
    bHash32(const char *name) {}
    bHash32(const bHash32 &from) : mCRC(from.mCRC) {}
    bHash32(unsigned int crc) : mCRC(crc) {}

    bHash32 &operator=(bHash32 &from) {
        this->mCRC = from.mCRC;
        return *this;
    }
    bHash32 &operator=(const char *from) {}

    unsigned int GetValue() {
        return mCRC;
    }
};

class UCrc32 {
  public:
    static const UCrc32 kNull;

    UCrc32() : mCRC(0) {}

    UCrc32(const char *name) : mCRC(stringhash(name)) {}

     

    UCrc32(const UCrc32 &from) : mCRC(from.mCRC) {}

    UCrc32(unsigned int crc) : mCRC(crc) {}

    UCrc32(const Attrib::StringKey &key) : mCRC(key.GetHash32()) {}

    const UCrc32 &operator=(const UCrc32 &from) {
        mCRC = from.mCRC;
        return *this;
    }

    const UCrc32 &operator=(const char *from) {
        UCrc32 tmp(from);
        mCRC = tmp.mCRC;
        return *this;
    }

    bool operator<(const UCrc32 &from) const {
        return mCRC < from.mCRC;
    }

    unsigned int GetValue() const {
        return mCRC;
    }

    void SetValue(unsigned int crc) {
        mCRC = crc;
    }

  private:
     
    unsigned int mCRC;  
};

inline bool operator==(const UCrc32 &a, const UCrc32 &b) {
    return a.GetValue() == b.GetValue();
}

inline bool operator!=(const UCrc32 &a, const UCrc32 &b) {
    return a.GetValue() != b.GetValue();
}

inline bool operator==(const UCrc32 &a, const char *b) {
    return a == UCrc32(b);
}

inline bool operator!=(const UCrc32 &a, const char *b) {
    return a != UCrc32(b);
}

inline bool operator==(const char *a, const UCrc32 &b) {
    return UCrc32(a) == b;
}

inline bool operator!=(const char *a, const UCrc32 &b) {
    return UCrc32(a) != b;
}


