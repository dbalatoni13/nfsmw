void PhysicsObject::OnBehaviorChange(const UCrc32 &mechanic) {
    if (mechanic == UCrc32(BEHAVIOR_MECHANIC_RIGIDBODY)) {
        IRigidBody *irb = __null  ;
        static_cast<ISimable *>(this)->QueryInterface(&irb);
