        unsigned char state;                               
        unsigned char index;                               
        char unused2;                                      
          UMath::Vector3 torque;                    
        float radius;                                      
          UMath::Matrix4 bodyMatrix;                
    };

  private:
    ScratchPtr<Volatile> mData;                            
