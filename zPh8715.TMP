inline bVector3 &bConvertFromBond(bVector3 &dest, const bVector3 &v) {
    float x = v.z;
    float y = v.x;
    float z = v.y;
    dest.x = x;
    dest.y = -y;
    dest.z = z;

    return dest;
}

inline bVector3 &bConvertToBond(bVector3 &dest, const bVector3 &v) {
    float x = v.y;
    float y = v.z;
    float z = v.x;
    dest.x = -x;
    dest.y = y;
    dest.z = z;

    return dest;
}

