        this->mColour = 0;
        this->mSize = 0.0f;
        this->mPosX = 0.0f;
        this->mPosY = 0.0f;
        this->mPosZ = 0.0f;
        this->mFlags = 0;
        this->mUVStart = 0;
        this->mUVEnd = 0;
        this->mLife = 0;
        this->mAngle = 0;
        this->mAnimFrame = 0;
        this->mInitialAngle = 0;
