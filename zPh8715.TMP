    bool IsHidden() const  ;
    void HideModel()  ;
    void OnBeginDraw()  ;
    void OnEndSimulation()  ;

    static void InitSystem();
    static void RestoreSystem();

  private:
    void InitScene();
    void StartOverride();
    void EndOverride();
    void ShowInstance(bool show);

    bool mInstanceVisible;
    SmokeableSpawner *mSpawner;

    static int mSceneryCount;

    friend class SmokeableSpawner;
};


