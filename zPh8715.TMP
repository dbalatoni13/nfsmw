        hNewNameHash = name_hash;
    }

    void SetExplicit(unsigned int name_hash, TextureInfo *pRepTextureInfo) {}

    TextureInfo *GetCurrentTexture() {
        return pTextureInfo;
    }

    void SetCurrentTexture(TextureInfo *texture_info) {
        this->pTextureInfo = texture_info;
    }
};

