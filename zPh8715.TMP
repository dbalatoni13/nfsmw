struct WRoadIntersection {
    UMath::Vector3 fPosition;     
    short fIndex;                 
    unsigned char fNumConnected;  
    short fConnected[7];          
    unsigned char fNumEntrances;  
    short fEntrances[7];          
    unsigned char fOccupied[7];   
    char fPad[9];                 
};

 
struct WRoadSegment {
    bool IsDecision() const {
        return fFlags & 1;
    }

     

    bool CopsXorTraffic() const {
        return fFlags & (1 << 5);
    }

    bool IsTrafficAllowed() const {
        return !(fFlags & 2);
    }

    bool ShouldCopsConsider() const {
        return IsTrafficAllowed() ^ CopsXorTraffic();
    }

     

     

     

     

     

     

     

     

     

     

    bool IsInRace() const {
        return fFlags & (1 << 15);
    }

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     

     
    unsigned short fNodeIndex[2];       
    unsigned short nLength;             
    short fRoadID;                      
    short fIndex;                       
    unsigned short fFlags;              
    unsigned short fEndHandleLength;    
    unsigned short fStartHandleLength;  
    char vEndHandle[3];                 
    char vStartHandle[3];               
};


