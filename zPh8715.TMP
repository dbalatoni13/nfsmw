inline float Limit(const float a, const float l) {
    float retval;
    if (!(a * l > 0.f)) {
        retval = a;
    } else {
        if (a > 0.f) {
            retval = Min(a, l);

        } else {
            retval = Max(a, l);
        }
    }
    return retval;
}

