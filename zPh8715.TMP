    float y1 = y;
    float z1 = z;
    float w1 = w;

    float x2 = v.x;
    float y2 = v.y;
    float z2 = v.z;
    float w2 = v.w;

    float _x = x1 - x2;
    float _y = y1 - y2;
    float _z = z1 - z2;
    float _w = w1 - w2;

    return bVector4(_x, _y, _z, _w);
