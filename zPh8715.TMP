void _S_sort(  list     <_Tp, _Alloc>& __that, _StrictWeakOrdering __comp) {
   
  if (__that._M_node._M_data->_M_next != __that._M_node._M_data &&
      (__that._M_node._M_data->_M_next)->_M_next != __that._M_node._M_data) {
