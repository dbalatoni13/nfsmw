inline bVector4 *bAdd(bVector4 *dest, const bVector4 *v1, const bVector4 *v2) {
    float x1 = v1->x;
    float y1 = v1->y;
    float z1 = v1->z;
    float w1 = v1->w;
    float x2 = v2->x;
    float y2 = v2->y;
    float z2 = v2->z;
    float w2 = v2->w;

    dest->x = x1 + x2;
    dest->y = y1 + y2;
    dest->z = z1 + z2;
    dest->w = w1 + w2;
}

