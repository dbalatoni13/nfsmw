};

struct bVirtualMemoryManager {
     
    uintptr_t mVirtualBaseAddr;  
    uintptr_t mARamBaseAddr;     
    unsigned int mARamSize;      
    uintptr_t mMRamBaseAddr;     
    unsigned int mMRamSize;      
    unsigned int bIsValid;       

    void Init();
