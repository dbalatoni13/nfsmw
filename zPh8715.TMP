namespace CollisionGeometry {

enum BoundFlags {
    kBounds_Joint_Invert = 8192,
    kBounds_Male_Post = 4096,
    kBounds_Joint_Male = 2048,
    kBounds_Joint_Female = 1024,
    kBounds_Constraint_Prismatic = 512,
    kBounds_Constraint_Conical = 256,
    kBounds_Sphere = 128,
    kBounds_Box = 64,
    kBounds_Internal = 32,
