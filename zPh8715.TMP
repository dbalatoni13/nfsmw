  return __copy_ptrs(__first, __last, __result, 
                     _IsOKToMemCpy((typename iterator_traits<   _InputIter  >::value_type*)0 , 
                                   (typename iterator_traits<   _OutputIter  >::value_type*)0 )._Ret());
